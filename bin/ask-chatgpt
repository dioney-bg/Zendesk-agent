#!/bin/bash
#
# Ask ChatGPT - Interactive Terminal Chat
# Chat with ChatGPT directly from your terminal
#

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Project directory (resolve symlinks to find actual script location)
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlink if necessary (macOS compatible)
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Check if virtual environment exists
if [ ! -d "$PROJECT_DIR/venv" ]; then
    echo -e "${RED}❌ Virtual environment not found${NC}"
    echo ""
    echo "Please run setup first:"
    echo "  cd $PROJECT_DIR"
    echo "  make setup"
    echo ""
    exit 1
fi

# Check if .env file exists with API key
if [ ! -f "$PROJECT_DIR/.env" ]; then
    echo -e "${RED}❌ API key not configured${NC}"
    echo ""
    echo "Please create .env file with your Zendesk AI Gateway key:"
    echo "  echo 'ZENDESK_AI_GATEWAY_KEY=your_key_here' > $PROJECT_DIR/.env"
    echo ""
    exit 1
fi

# Navigate to project directory
cd "$PROJECT_DIR"

# Activate virtual environment and run ChatGPT terminal
source venv/bin/activate
exec python scripts/core/chatgpt_terminal.py

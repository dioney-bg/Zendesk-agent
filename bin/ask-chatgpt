#!/bin/bash
#
# Ask ChatGPT - Interactive Terminal Chat
# Chat with ChatGPT directly from your terminal
#

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function to check VPN and API access
check_vpn_and_auth() {
    # Load API key
    if [ ! -f "$PROJECT_DIR/.env" ]; then
        return 2  # No .env file
    fi

    API_KEY=$(grep "ZENDESK_AI_GATEWAY_KEY=" "$PROJECT_DIR/.env" | cut -d'=' -f2)

    if [ -z "$API_KEY" ]; then
        return 2  # No API key
    fi

    # Test actual API access with the key
    HTTP_CODE=$(curl -s --connect-timeout 5 \
        -H "Authorization: Bearer $API_KEY" \
        -o /dev/null -w "%{http_code}" \
        https://ai-gateway.zende.sk/v1/models 2>&1)

    if [[ "$HTTP_CODE" == "200" ]]; then
        return 0  # Authenticated and authorized
    elif [[ "$HTTP_CODE" == "401" ]] || [[ "$HTTP_CODE" == "403" ]]; then
        return 3  # VPN up but auth failed
    elif [[ "$HTTP_CODE" =~ ^[0-9]{3}$ ]]; then
        return 0  # Some HTTP response, consider connected
    else
        return 1  # No connection (VPN down)
    fi
}

# Check VPN and auth status
check_vpn_and_auth
AUTH_STATUS=$?

if [ $AUTH_STATUS -eq 3 ]; then
    # VPN connected but auth failed (SSO expired)
    echo -e "${YELLOW}⚠️  API authentication expired${NC}"
    echo -e "${BLUE}Opening browser for SSO login...${NC}"
    echo ""

    # Open the SSO login page
    open "https://ai-gateway.zende.sk/v1/models"

    echo -e "${YELLOW}Please complete SSO authentication in your browser${NC}"
    echo -e "${BLUE}After logging in, press Enter to continue...${NC}"
    read -r

    # Verify auth is working
    check_vpn_and_auth
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Still not authenticated${NC}"
        echo ""
        echo "Troubleshooting:"
        echo "  1. Check your API key in .env file"
        echo "  2. Try regenerating your API key"
        echo "  3. Contact IT if issue persists"
        echo ""
        exit 1
    fi

    echo -e "${GREEN}✅ Authentication successful!${NC}"
    echo ""

elif [ $AUTH_STATUS -eq 1 ]; then
    # VPN not connected
    echo -e "${YELLOW}⚠️  VPN not connected${NC}"
    echo -e "${BLUE}Opening GlobalProtect...${NC}"
    echo ""

    # Open GlobalProtect app
    open -a GlobalProtect

    echo -e "${YELLOW}Please connect to VPN in GlobalProtect${NC}"
    echo -e "${BLUE}Waiting for connection...${NC}"
    echo ""

    # Wait for VPN connection (check every 2 seconds, max 60 seconds)
    MAX_ATTEMPTS=30
    ATTEMPT=0

    while [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do
        sleep 2
        ATTEMPT=$((ATTEMPT + 1))

        check_vpn_and_auth
        STATUS=$?

        if [ $STATUS -eq 0 ]; then
            echo -e "${GREEN}✅ VPN connected and authenticated!${NC}"
            echo ""
            break
        elif [ $STATUS -eq 3 ]; then
            echo -e "${GREEN}✅ VPN connected!${NC}"
            echo -e "${YELLOW}⚠️  But authentication needed (SSO expired)${NC}"
            echo ""
            open "https://ai-gateway.zende.sk/v1/models"
            echo -e "${YELLOW}Please complete SSO login in browser, then press Enter...${NC}"
            read -r
            break
        fi

        # Show progress
        if [ $((ATTEMPT % 5)) -eq 0 ]; then
            echo -e "${BLUE}Still waiting... (${ATTEMPT}/${MAX_ATTEMPTS})${NC}"
        fi
    done

    # Final check
    check_vpn_and_auth
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ VPN connection timeout${NC}"
        echo ""
        echo "Please:"
        echo "  1. Connect to GlobalProtect VPN manually"
        echo "  2. Complete SSO authentication if needed"
        echo "  3. Run this command again"
        echo ""
        exit 1
    fi

elif [ $AUTH_STATUS -eq 2 ]; then
    # No API key configured - let script handle error
    :
fi

# Project directory (resolve symlinks to find actual script location)
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlink if necessary (macOS compatible)
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Check if virtual environment exists
if [ ! -d "$PROJECT_DIR/venv" ]; then
    echo -e "${RED}❌ Virtual environment not found${NC}"
    echo ""
    echo "Please run setup first:"
    echo "  cd $PROJECT_DIR"
    echo "  make setup"
    echo ""
    exit 1
fi

# Check if .env file exists with API key
if [ ! -f "$PROJECT_DIR/.env" ]; then
    echo -e "${RED}❌ API key not configured${NC}"
    echo ""
    echo "Please create .env file with your Zendesk AI Gateway key:"
    echo "  echo 'ZENDESK_AI_GATEWAY_KEY=your_key_here' > $PROJECT_DIR/.env"
    echo ""
    exit 1
fi

# Navigate to project directory
cd "$PROJECT_DIR"

# Activate virtual environment and run ChatGPT terminal
source venv/bin/activate
exec python scripts/core/chatgpt_terminal.py

#!/bin/bash
#
# Install strategy-agent command globally
# Makes 'strategy-agent' available from any directory
#

set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_PATH="$PROJECT_DIR/bin/strategy-agent"

echo -e "${BLUE}Installing strategy-agent command...${NC}"
echo ""

# Check if script exists
if [ ! -f "$SCRIPT_PATH" ]; then
    echo -e "${RED}❌ Could not find strategy-agent script${NC}"
    exit 1
fi

# Determine installation location
if [ -d "$HOME/.local/bin" ]; then
    INSTALL_DIR="$HOME/.local/bin"
elif [ -d "$HOME/bin" ]; then
    INSTALL_DIR="$HOME/bin"
else
    # Create ~/.local/bin if it doesn't exist
    mkdir -p "$HOME/.local/bin"
    INSTALL_DIR="$HOME/.local/bin"
fi

# Create symlink
SYMLINK_PATH="$INSTALL_DIR/strategy-agent"

if [ -L "$SYMLINK_PATH" ]; then
    echo -e "${YELLOW}⚠️  Symlink already exists, removing old one...${NC}"
    rm "$SYMLINK_PATH"
fi

ln -s "$SCRIPT_PATH" "$SYMLINK_PATH"

echo -e "${GREEN}✅ Installed strategy-agent to: $SYMLINK_PATH${NC}"
echo ""

# Check if directory is in PATH
if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    echo -e "${YELLOW}⚠️  $INSTALL_DIR is not in your PATH${NC}"
    echo ""
    echo "Add this to your ~/.zshrc or ~/.bashrc:"
    echo ""
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo ""
    echo "Then run: source ~/.zshrc"
    echo ""
else
    echo -e "${GREEN}✅ $INSTALL_DIR is in your PATH${NC}"
    echo ""
    echo -e "${GREEN}You can now run 'strategy-agent' from any directory!${NC}"
    echo ""
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Test it by running:"
echo ""
echo "  strategy-agent"
echo ""

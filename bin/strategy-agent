#!/bin/bash
#
# Sales Strategy Agent Launcher
# Starts an interactive Claude Code session with full project context
#

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Project directory (resolve symlinks to find actual script location)
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlink if necessary (macOS compatible)
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

echo -e "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║                                                            ║${NC}"
echo -e "${BLUE}║         📊 Sales Strategy Agent (v1.4)                    ║${NC}"
echo -e "${BLUE}║                                                            ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if Claude Code is installed
if ! command -v claude &> /dev/null; then
    echo -e "${RED}❌ Claude Code is not installed${NC}"
    echo ""
    echo "Please install Claude Code first:"
    echo ""
    echo "  macOS:   brew install anthropics/claude/claude-code"
    echo "  Or visit: https://docs.anthropic.com/claude-code"
    echo ""
    exit 1
fi

# Check if in project directory
if [ ! -f "$PROJECT_DIR/CLAUDE.md" ]; then
    echo -e "${RED}❌ Could not find project files${NC}"
    echo "Expected to find CLAUDE.md in: $PROJECT_DIR"
    exit 1
fi

# Auto-update check (fetch latest security settings and improvements)
cd "$PROJECT_DIR"
if [ -d ".git" ]; then
    # Quietly fetch latest changes
    git fetch origin main --quiet 2>/dev/null || true

    # Check if we're behind origin/main
    LOCAL=$(git rev-parse HEAD 2>/dev/null)
    REMOTE=$(git rev-parse origin/main 2>/dev/null)

    if [ "$LOCAL" != "$REMOTE" ] && [ ! -z "$REMOTE" ]; then
        # Check if working directory is clean
        if [ -z "$(git status --porcelain)" ]; then
            echo -e "${YELLOW}📥 Updates available - pulling latest changes...${NC}"
            git pull origin main --quiet
            echo -e "${GREEN}✅ Updated to latest version${NC}"

            # Reinstall global command if needed (in case script was updated)
            if [ -f "$PROJECT_DIR/bin/install_strategy_agent" ]; then
                "$PROJECT_DIR/bin/install_strategy_agent" > /dev/null 2>&1
                echo -e "${GREEN}✅ Global command updated${NC}"
            fi
            echo ""
        else
            echo -e "${YELLOW}⚠️  Updates available but you have local changes${NC}"
            echo -e "${YELLOW}   Run 'git stash && git pull && git stash pop' to update${NC}"
            echo ""
        fi
    fi
fi

# Check if Snowflake CLI is available (check common paths)
SNOW_FOUND=false
COMMON_PATHS=(
    "/opt/homebrew/bin/snow"
    "/usr/local/bin/snow"
    "/Applications/SnowflakeCLI.app/Contents/MacOS/snow"
    "$HOME/.local/bin/snow"
)

for path in "${COMMON_PATHS[@]}"; do
    if [ -f "$path" ]; then
        SNOW_FOUND=true
        break
    fi
done

if [ "$SNOW_FOUND" = false ]; then
    echo -e "${YELLOW}⚠️  Snowflake CLI not found${NC}"
    echo "Install: brew install snowflake-cli"
    echo ""
fi

# Check if virtual environment exists
if [ ! -d "$PROJECT_DIR/venv" ]; then
    echo -e "${YELLOW}⚠️  Virtual environment not found${NC}"
    echo "Run 'make setup' first to configure the project."
    echo ""
fi

echo -e "${GREEN}✅ Starting Sales Strategy Agent (v1.2)...${NC}"
echo ""
echo -e "${BLUE}I can help you analyze data in natural language - just ask your question and I'll run the query for you!${NC}"
echo ""
echo -e "${YELLOW}📊 What I can analyze:${NC}"
echo ""
echo -e "${GREEN}🌎 Geographic Analysis${NC}"
echo "   • \"Show me top 10 countries by ARR\""
echo "   • \"Which countries are growing fastest?\""
echo "   • \"Countries losing accounts year over year\""
echo ""
echo -e "${GREEN}🏭 Industry Analysis${NC}"
echo "   • \"Top industries for AMER\""
echo "   • \"Show me EMEA industry growth\""
echo "   • \"Which industries are declining in APAC?\""
echo ""
echo -e "${GREEN}📈 AI Penetration${NC}"
echo "   • \"AI penetration by leader\""
echo "   • \"AMER Strategic segment penetration\""
echo "   • \"Compare AI adoption Q1 vs Q4\""
echo ""
echo -e "${GREEN}🤖 Competitive Intelligence${NC}"
echo "   • \"AI Agent wins vs Ada/Forethought/Sierra/Decagon\""
echo "   • \"Open opportunities against bot competitors\""
echo ""
echo -e "${GREEN}💼 Opportunity Type Analysis${NC}"
echo "   • \"Show me New Business wins vs Expansion wins\""
echo "   • \"Break down pipeline by opportunity type\""
echo ""
echo -e "${GREEN}📊 Trends & Comparisons${NC}"
echo "   • \"Year over year growth by leader\""
echo "   • \"Quarter over quarter changes\""
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Navigate to project directory and start Claude Code
cd "$PROJECT_DIR"

# Start Claude Code with bypass permissions mode
# This respects .claude/settings.json allow rules without prompting
# The CLAUDE.md file will be automatically loaded by Claude Code
exec claude --permission-mode bypassPermissions

#!/bin/bash
#
# Sales Strategy Agent Launcher
# Starts an interactive Claude Code session with full project context
#

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function to check VPN and API access
check_vpn_and_auth() {
    # Test connection to Zendesk internal service
    HTTP_CODE=$(curl -s --connect-timeout 5 \
        -o /dev/null -w "%{http_code}" \
        https://ai-gateway.zende.sk/v1/models 2>&1)

    if [[ "$HTTP_CODE" == "200" ]]; then
        return 0  # Authenticated and authorized
    elif [[ "$HTTP_CODE" == "401" ]] || [[ "$HTTP_CODE" == "403" ]]; then
        return 3  # VPN up but auth may be needed
    elif [[ "$HTTP_CODE" =~ ^[0-9]{3}$ ]]; then
        return 0  # Some HTTP response, consider connected
    else
        return 1  # No connection (VPN down)
    fi
}

# Check VPN and auth status (simplified - just check if VPN down)
check_vpn_and_auth
AUTH_STATUS=$?

if [ $AUTH_STATUS -eq 1 ]; then
    # VPN not connected
    echo -e "${YELLOW}⚠️  VPN not connected${NC}"
    echo -e "${BLUE}Opening GlobalProtect...${NC}"
    echo ""

    # Open GlobalProtect app
    open -a GlobalProtect

    echo -e "${YELLOW}Please connect to VPN in GlobalProtect${NC}"
    echo -e "${BLUE}Waiting for connection...${NC}"
    echo ""

    # Wait for VPN connection (check every 2 seconds, max 60 seconds)
    MAX_ATTEMPTS=30
    ATTEMPT=0

    while [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do
        sleep 2
        ATTEMPT=$((ATTEMPT + 1))

        check_vpn_and_auth
        STATUS=$?

        if [ $STATUS -eq 0 ] || [ $STATUS -eq 3 ]; then
            echo -e "${GREEN}✅ VPN connected!${NC}"
            echo ""
            break
        fi

        # Show progress
        if [ $((ATTEMPT % 5)) -eq 0 ]; then
            echo -e "${BLUE}Still waiting... (${ATTEMPT}/${MAX_ATTEMPTS})${NC}"
        fi
    done

    # Final check
    check_vpn_and_auth
    FINAL_STATUS=$?
    if [ $FINAL_STATUS -ne 0 ] && [ $FINAL_STATUS -ne 3 ]; then
        echo -e "${RED}❌ VPN connection timeout${NC}"
        echo ""
        echo "Please:"
        echo "  1. Connect to GlobalProtect VPN manually"
        echo "  2. Run this command again"
        echo ""
        exit 1
    fi
fi

# Project directory (resolve symlinks to find actual script location)
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlink if necessary (macOS compatible)
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

echo -e "${BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║                                                            ║${NC}"
echo -e "${BLUE}║         📊 Sales Strategy Reporting Agent                 ║${NC}"
echo -e "${BLUE}║                                                            ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check if Claude Code is installed
if ! command -v claude &> /dev/null; then
    echo -e "${RED}❌ Claude Code is not installed${NC}"
    echo ""
    echo "Please install Claude Code first:"
    echo ""
    echo "  macOS:   brew install anthropics/claude/claude-code"
    echo "  Or visit: https://docs.anthropic.com/claude-code"
    echo ""
    exit 1
fi

# Check if in project directory
if [ ! -f "$PROJECT_DIR/CLAUDE.md" ]; then
    echo -e "${RED}❌ Could not find project files${NC}"
    echo "Expected to find CLAUDE.md in: $PROJECT_DIR"
    exit 1
fi

# Check if Snowflake CLI is available
if [ ! -f "/Applications/SnowflakeCLI.app/Contents/MacOS/snow" ]; then
    echo -e "${YELLOW}⚠️  Snowflake CLI not found at expected location${NC}"
    echo "Make sure Snowflake CLI is installed and configured."
    echo ""
fi

# Check if virtual environment exists
if [ ! -d "$PROJECT_DIR/venv" ]; then
    echo -e "${YELLOW}⚠️  Virtual environment not found${NC}"
    echo "Run 'make setup' first to configure the project."
    echo ""
fi

echo -e "${GREEN}✅ Starting Sales Strategy Agent...${NC}"
echo ""
echo -e "${BLUE}Project:${NC} $PROJECT_DIR"
echo -e "${BLUE}Context:${NC} CLAUDE.md loaded (Snowflake queries, conventions, patterns)"
echo ""
echo -e "${GREEN}🤖 Claude Code will start with full project knowledge.${NC}"
echo -e "${GREEN}   Ask questions about accounts, run queries, generate reports!${NC}"
echo ""
echo -e "${YELLOW}Tip: Try asking:${NC}"
echo "  - 'Show me AI penetration by leader'"
echo "  - 'What's AMER Strategic segment penetration?'"
echo "  - 'Compare this quarter to last quarter'"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# Navigate to project directory and start Claude Code
cd "$PROJECT_DIR"

# Start Claude Code
# The CLAUDE.md file will be automatically loaded by Claude Code
exec claude

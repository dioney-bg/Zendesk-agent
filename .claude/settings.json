{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(snow:*)",
      "Bash(/opt/homebrew/bin/snow:*)",
      "Bash(/usr/local/bin/snow:*)",
      "Bash(/Applications/SnowflakeCLI.app/Contents/MacOS/snow:*)",
      "Bash(*snow*:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Read(*)",
      "Write(/tmp/*)",
      "Bash(*:/tmp/*)",
      "Read(outputs/*)",
      "Write(outputs/*)",
      "Bash(*:outputs/*)"
    ]
  }
}
